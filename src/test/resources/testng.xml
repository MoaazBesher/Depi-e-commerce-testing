<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  ============================================================
   DEPI MarketSpace - Master Test Suite
   Run via: mvn test  OR  right-click this file > Run in IDE
  ============================================================
-->
<suite name="DEPI MarketSpace Test Suite" verbose="1">

    <!-- Professional console + HTML reporting -->
    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <test name="Regression Suite">
        <classes>
            <!-- Login Tests -->
            <class name="tests.LoginTest"/>

            <!-- Home Page Navigation Tests -->
            <class name="tests.TestCart"/>
            <class name="tests.TestProduct"/>
            <class name="tests.TestSearch"/>

            <!-- Full Cart Flow Tests -->
            <class name="tests.CartTest"/>

            <!-- Product Detail Page Tests -->
            <class name="tests.ProductTest"/>

            <!-- End-to-End Checkout Tests -->
            <class name="tests.CheckoutTest"/>
        </classes>
    </test>

</suite>
